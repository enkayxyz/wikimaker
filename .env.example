# WikiMaker local environment
# Copy this file to .env and fill in your local inference settings.

# Local Ollama server for this machine
# Use 127.0.0.1 only when Ollama is running on the same machine as WikiMaker.
# No API key is required for plain Ollama.
OPENAI_BASE_URL=http://127.0.0.1:11434
WIKIMAKER_PROVIDER=ollama
WIKIMAKER_LLM_API_STYLE=ollama
WIKIMAKER_ALLOW_REMOTE_LLM=0

# Optional local prompt profile overrides.
# WIKIMAKER_PROMPT_PROFILE=/path/to/wikimaker.profiles.json

# Default synthesis is cached per-file map/reduce. coverage_fallback is the
# offline scan-only path; llm_only is the legacy one-shot expert mode.
WIKIMAKER_SYNTHESIS_MODE=map_reduce
WIKIMAKER_LLM_BATCH_SIZE=50
# WIKIMAKER_FORCE_REPROCESS=0
# WIKIMAKER_FORCE_PATHS=notes/*.md,bills/example.md
WIKIMAKER_ENABLE_QUALITY_JUDGE=1
# WIKIMAKER_QUALITY_JUDGE_MODEL=gemma4:e4b-mlx

# If you switch back to an OpenAI-compatible server, you can set:
# OPENAI_API_KEY=***
# OSAURUS_API_KEY=***

# Model settings for your local server
# WIKIMAKER_ANALYSIS_MODEL=gemma4:e4b-mlx
# WIKIMAKER_GENERATION_MODEL=gemma4:e4b-mlx
# WIKIMAKER_REVIEW_MODEL=gemma4:e4b-mlx
